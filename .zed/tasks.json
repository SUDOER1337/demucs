  {
    "label": "Install ROCm torchaudio",
    "command": "make install-rocm-torchaudio",
    "cwd": "$ZED_WORKTREE_ROOT"
  },
  {
    "label": "Install TUI binary (cargo)",
    "command": "make tui-install",
    "cwd": "$ZED_WORKTREE_ROOT"
  },
  {
    "label": "Lint Python",
    "command": "make linter",
    "cwd": "$ZED_WORKTREE_ROOT"
  },
  {
    "label": "Smoke test",
    "command": "make smoke",
    "cwd": "$ZED_WORKTREE_ROOT"
  },
  {
